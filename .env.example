# Database (PostgreSQL via Supabase or Railway)
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/peptora

# Security — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace-with-256-bit-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_MONTHLY_PRICE_ID=price_...
STRIPE_ANNUAL_PRICE_ID=price_...

# AI
ANTHROPIC_API_KEY=sk-ant-...

# Email
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@peptora.app

# App
FRONTEND_URL=https://peptora.app
ADMIN_URL=https://admin.peptora.app
ENVIRONMENT=production
